# 1. Використовуємо легкий образ з Node.js
FROM node:20-slim

# 2. Встановлюємо сервер для статичних файлів
RUN npm install -g serve

# 3. Створюємо папку додатка в контейнері
WORKDIR /app

# 4. Копіюємо вміст твоєї папки html
COPY html/ .

# 5. Відкриваємо порт 3000
EXPOSE 3000

# 6. Запускаємо сервер
CMD ["serve", "-s", ".", "-l", "3000"]